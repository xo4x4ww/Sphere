# Обязательно
BOT_TOKEN=ваш_токен_от_BotFather

# ID админов через запятую
ADMIN_IDS=123456789

# ПРОКСИ ДЛЯ РОССИИ (раскомментируйте нужный):
# Вариант 1: SOCKS5 (рекомендуется, купить у ботов)
# PROXY_URL=socks5://логин:пароль@ip:порт

# Вариант 2: HTTP
# PROXY_URL=http://логин:пароль@ip:порт

# Если используете VPN или вам не нужен прокси:
# PROXY_URL=

# Остальное
STATS_INTERVAL=86400
DEFAULT_LANGUAGE=ru